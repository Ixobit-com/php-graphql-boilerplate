COMPOSE_PROJECT_NAME=graphql
NETWORK_NAME=graphql-local-network

USER_ID=
GROUP_ID=

## Hosts (comma separated)
HOSTS=graphql.local

## Ports (external)
PORT_MYSQL=33066
PORT_MAIL_SMTP=1025
PORT_MAIL_GUI=8025

## Database config
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=graphql
MYSQL_USER=graphql
MYSQL_PASSWORD=graphql

SUBNET_IP=172.21.0.0/24

XDEBUG_SERVER_NAME=Docker
XDEBUG_CLIENT_PORT=9001
