COMPOSE_PROJECT_NAME=graphql
NETWORK_NAME=local-network

USER_ID=1000
GROUP_ID=1000

## Hosts (comma separated)
HOSTS=graphql.local

## Ports (external)
PORT_MYSQL=33066
PORT_MAIL_SMTP=1025
PORT_MAIL_GUI=8025

## Database config (There is not recommend to change this vars because some values may be hardcoded in another projects files - SQL, PHP etc.)
MYSQL_HOST=mysql
MYSQL_PORT=3306
MYSQL_ROOT_PASSWORD=root
MYSQL_DATABASE=graphql
MYSQL_USER=graphql
MYSQL_PASSWORD=graphql

SUBNET_IP=172.21.0.0/24
HOST_IP=172.17.0.1

XDEBUG_SERVER_NAME=Docker
XDEBUG_CLIENT_PORT=9001
